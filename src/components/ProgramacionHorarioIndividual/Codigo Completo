const SHIFTS_DATA = [
    { id: 'morning', name: 'Mañana', time: '08:00 - 12:00', icon: 'Sun' },
    { id: 'afternoon', name: 'Tarde', time: '14:00 - 18:00', icon: 'CloudSun' },
    { id: 'evening', name: 'Noche', time: '18:00 - 20:00', icon: 'Moon' },
